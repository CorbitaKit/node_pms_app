PORT=8001

DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pms_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Prisma requires DATABASE_URL
DATABASE_URL="postgresql://your_db_username:your_db_password@postgres:5432/pms_db"

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_IN=7d